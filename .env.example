# ─── MySQL ──────────────────────────────────────
MYSQL_ROOT_PASSWORD=rootpass
MYSQL_DATABASE=techpulse
MYSQL_USER=techpulse
MYSQL_PASSWORD=techpass
MYSQL_HOST=localhost
MYSQL_PORT=3306

# ─── Ports exposés (Docker) ─────────────────────
PHPMYADMIN_PORT=8080
FRONTEND_PORT=8000
API_PORT=5001    # 5000 occupé par AirPlay Receiver sur macOS

# ─── API France Travail ─────────────────────────
# Obtenir une clé : https://pole-emploi.io
FRANCE_TRAVAIL_CLIENT_ID=
FRANCE_TRAVAIL_CLIENT_SECRET=

# ─── Adresse API (géocodage) ────────────────────
ADRESSE_API_URL=https://api-adresse.data.gouv.fr

# ─── Application ────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
LOG_FORMAT=text
