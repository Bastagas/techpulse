{% extends 'layout.twig' %}
{% block title %}Comparateur{% endblock %}

{% block content %}
<section class="mb-6">
    <h1 class="text-2xl font-bold mb-1">Comparateur d'offres</h1>
    <p class="text-sm text-gray-600 dark:text-gray-400">
        Compare jusqu'à 4 offres côté à côté. Coche les offres depuis la recherche puis clique "Comparer".
    </p>
</section>

{% if offers|length == 0 %}
<div class="bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-800 rounded-xl p-8 text-center">
    <p class="text-gray-500 dark:text-gray-400 mb-4">Aucune offre sélectionnée.</p>
    <a href="/search.php" class="inline-block px-5 py-2 bg-brand-600 hover:bg-brand-700 text-white rounded-md">
        ← Retour à la recherche
    </a>
</div>
{% else %}

<div class="overflow-x-auto">
<table class="min-w-full bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-800 rounded-xl">
    <thead>
        <tr>
            <th class="sticky left-0 bg-gray-50 dark:bg-gray-800 p-3 text-left font-semibold text-sm border-b border-gray-200 dark:border-gray-800" style="width:180px;">Critère</th>
            {% for offer in offers %}
            <th class="p-3 text-left border-b border-gray-200 dark:border-gray-800 align-top" style="min-width: 280px;">
                <a href="/offer.php?id={{ offer.id }}" class="font-semibold text-brand-600 dark:text-brand-400 hover:underline line-clamp-2">{{ offer.title }}</a>
                <p class="text-xs text-gray-600 dark:text-gray-400 mt-1">{{ offer.company_name }}</p>
            </th>
            {% endfor %}
        </tr>
    </thead>
    <tbody class="text-sm">
        <tr>
            <td class="sticky left-0 bg-gray-50 dark:bg-gray-800 p-3 font-medium border-b border-gray-100 dark:border-gray-800">Ville</td>
            {% for o in offers %}<td class="p-3 border-b border-gray-100 dark:border-gray-800">{{ o.city ?: '—' }}{% if o.department_code %} ({{ o.department_code }}){% endif %}</td>{% endfor %}
        </tr>
        <tr>
            <td class="sticky left-0 bg-gray-50 dark:bg-gray-800 p-3 font-medium border-b border-gray-100 dark:border-gray-800">Contrat</td>
            {% for o in offers %}<td class="p-3 border-b border-gray-100 dark:border-gray-800">{{ o.contract_type ?: '—' }}</td>{% endfor %}
        </tr>
        <tr>
            <td class="sticky left-0 bg-gray-50 dark:bg-gray-800 p-3 font-medium border-b border-gray-100 dark:border-gray-800">Expérience</td>
            {% for o in offers %}<td class="p-3 border-b border-gray-100 dark:border-gray-800">{{ o.experience_level ?: '—' }}</td>{% endfor %}
        </tr>
        <tr>
            <td class="sticky left-0 bg-gray-50 dark:bg-gray-800 p-3 font-medium border-b border-gray-100 dark:border-gray-800">Séniorité (ML)</td>
            {% for o in offers %}<td class="p-3 border-b border-gray-100 dark:border-gray-800">
                {% set senLabels = {junior: 'Junior', mid: 'Confirmé', senior: 'Senior', lead: 'Lead'} %}
                {{ senLabels[o.seniority]|default('—') }}
            </td>{% endfor %}
        </tr>
        <tr>
            <td class="sticky left-0 bg-gray-50 dark:bg-gray-800 p-3 font-medium border-b border-gray-100 dark:border-gray-800">Télétravail</td>
            {% for o in offers %}<td class="p-3 border-b border-gray-100 dark:border-gray-800">
                {% set remLabels = {full_remote: '🏠 Full remote', hybrid: '↔ Hybride', on_site: '🏢 Sur site'} %}
                {{ remLabels[o.remote_policy]|default('—') }}
            </td>{% endfor %}
        </tr>
        <tr>
            <td class="sticky left-0 bg-gray-50 dark:bg-gray-800 p-3 font-medium border-b border-gray-100 dark:border-gray-800">Salaire</td>
            {% for o in offers %}<td class="p-3 border-b border-gray-100 dark:border-gray-800 font-semibold text-emerald-600 dark:text-emerald-400">
                {% if o.salary_min %}{{ o.salary_min|salary }}{% if o.salary_max and o.salary_max > o.salary_min %} – {{ o.salary_max|salary }}{% endif %}{% else %}—{% endif %}
            </td>{% endfor %}
        </tr>
        <tr>
            <td class="sticky left-0 bg-gray-50 dark:bg-gray-800 p-3 font-medium border-b border-gray-100 dark:border-gray-800 align-top">Technologies</td>
            {% for o in offers %}<td class="p-3 border-b border-gray-100 dark:border-gray-800 align-top">
                <div class="flex flex-wrap gap-1">
                    {% for tech in o.technologies %}
                        {% include 'partials/tech_badge.twig' with { tech: tech } %}
                    {% else %}<span class="text-gray-400">—</span>{% endfor %}
                </div>
            </td>{% endfor %}
        </tr>
        <tr>
            <td class="sticky left-0 bg-gray-50 dark:bg-gray-800 p-3 font-medium align-top">Extrait</td>
            {% for o in offers %}<td class="p-3 align-top text-xs text-gray-600 dark:text-gray-400">
                {{ o.description|excerpt(250) }}
            </td>{% endfor %}
        </tr>
    </tbody>
</table>
</div>
{% endif %}
{% endblock %}
