{% extends 'layout.twig' %}

{% block title %}{{ offer.title }}{% endblock %}

{% block content %}
<a href="javascript:history.back()" class="inline-flex items-center gap-1 text-sm text-gray-600 dark:text-gray-400 hover:text-gray-900 dark:hover:text-gray-100 mb-6">
    ← Retour
</a>

<article class="bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-800 rounded-2xl p-6 sm:p-8">
    <header class="mb-6">
        <div class="flex flex-wrap items-center gap-2 mb-3">
            {% if offer.contract_type %}
            <span class="text-xs font-medium px-2 py-1 rounded bg-gray-100 dark:bg-gray-800">{{ offer.contract_type }}</span>
            {% endif %}
            {% if offer.experience_level %}
            <span class="text-xs font-medium px-2 py-1 rounded bg-gray-100 dark:bg-gray-800">{{ offer.experience_level }}</span>
            {% endif %}
            <span class="text-xs text-gray-500 dark:text-gray-400">
                Source : {{ offer.source }}{% if offer.posted_at %} · publiée {{ offer.posted_at|ago }}{% endif %}
            </span>
        </div>
        <h1 class="text-3xl font-bold tracking-tight">{{ offer.title }}</h1>
        <p class="mt-2 text-lg text-gray-700 dark:text-gray-300">
            <span class="font-semibold">{{ offer.company_name }}</span>
            {% if offer.city %}
            <span class="mx-2 text-gray-400">·</span>
            <span>{{ offer.city }}{% if offer.department_code %} ({{ offer.department_code }}){% endif %}</span>
            {% endif %}
        </p>
    </header>

    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-6">
        {% if offer.salary_min %}
        <div class="bg-emerald-50 dark:bg-emerald-950/30 border border-emerald-200 dark:border-emerald-900 rounded-lg p-4">
            <p class="text-xs uppercase tracking-wide text-emerald-700 dark:text-emerald-300 font-semibold">Rémunération</p>
            <p class="mt-1 text-xl font-bold text-emerald-700 dark:text-emerald-300">
                {{ offer.salary_min|salary }}{% if offer.salary_max and offer.salary_max > offer.salary_min %}<br><span class="text-sm font-normal">à {{ offer.salary_max|salary }}</span>{% endif %}
            </p>
        </div>
        {% endif %}

        {% if offer.technologies|length > 0 %}
        <div class="bg-brand-50 dark:bg-brand-950/30 border border-brand-200 dark:border-brand-900 rounded-lg p-4 sm:col-span-2">
            <p class="text-xs uppercase tracking-wide text-brand-700 dark:text-brand-300 font-semibold mb-2">Technologies détectées · {{ offer.technologies|length }}</p>
            <div class="flex flex-wrap gap-1.5">
                {% for tech in offer.technologies %}
                    {% include 'partials/tech_badge.twig' with { tech: tech } %}
                {% endfor %}
            </div>
        </div>
        {% endif %}
    </div>

    {% if offer.description %}
    <div class="prose prose-gray dark:prose-invert max-w-none mb-6">
        <h2 class="text-lg font-semibold text-gray-900 dark:text-white">Description du poste</h2>
        <div class="whitespace-pre-wrap text-gray-700 dark:text-gray-300 leading-relaxed">{{ offer.description }}</div>
    </div>
    {% endif %}

    {# ─── Estimation salaire ML ─── #}
    {% if salary_prediction and salary_prediction.available %}
    <div class="bg-violet-50 dark:bg-violet-950/30 border border-violet-200 dark:border-violet-900 rounded-lg p-4 mb-6">
        <div class="flex items-start gap-3">
            <svg class="h-6 w-6 text-violet-600 dark:text-violet-400 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/>
            </svg>
            <div class="flex-1">
                <p class="text-xs uppercase tracking-wide text-violet-700 dark:text-violet-300 font-semibold">Estimation salariale (scikit-learn)</p>
                <p class="mt-1 text-xl font-bold text-violet-900 dark:text-violet-200">
                    {{ salary_prediction.prediction.low|salary }} – {{ salary_prediction.prediction.high|salary }}
                </p>
                <p class="text-sm text-violet-700 dark:text-violet-300 mt-0.5">
                    point estimé : <strong>{{ salary_prediction.prediction.point|salary }}</strong>
                    · confiance : {{ (salary_prediction.prediction.confidence * 100)|round }}%
                </p>
                <p class="text-xs text-violet-600 dark:text-violet-400 mt-2">
                    Prédiction RandomForest entraîné sur {{ salary_prediction.model.training_size }} offres avec salaire renseigné,
                    {{ salary_prediction.model.feature_count }} features (technos + ville + contrat + expérience).
                    {% if salary_prediction.actual.salary_min %}
                    Salaire réel annoncé : <strong>{{ salary_prediction.actual.salary_min|salary }}</strong>.
                    {% endif %}
                </p>
            </div>
        </div>
    </div>
    {% endif %}

    {% if offer.source_url %}
    <div class="pt-6 border-t border-gray-200 dark:border-gray-800">
        <a href="{{ offer.source_url }}" target="_blank" rel="noopener"
           class="inline-flex items-center gap-2 px-4 py-2.5 rounded-lg bg-brand-600 hover:bg-brand-700 text-white font-medium">
            Postuler sur {{ offer.source|replace({'_': ' '})|title }}
            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
            </svg>
        </a>
    </div>
    {% endif %}
</article>
{% endblock %}
