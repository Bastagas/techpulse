{% extends 'layout.twig' %}
{% set active_page = 'search' %}

{% block title %}{{ offer.title }}{% endblock %}

{% block content %}

<a href="/search.php" class="inline-flex items-center gap-1.5 text-sm text-slate-400 hover:text-white mb-6 reveal">
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
    Retour aux offres
</a>

<div class="max-w-[1100px] mx-auto">

<!-- ─── HEADER OFFRE ─── -->
<article class="reveal glass-strong p-6 sm:p-8 mb-6 relative overflow-hidden iridescent" style="animation-delay:180ms">
    <div class="orb w-64 h-64 bg-red-500/20 -top-10 -right-10"></div>

    <div class="flex items-center gap-2 mb-4 flex-wrap">
        {% if offer.contract_type %}
        <span class="px-2 py-0.5 rounded-full bg-red-500/20 text-red-400 text-[10px] mono uppercase tracking-wider">{{ offer.contract_type }}</span>
        {% endif %}
        {% if offer.seniority %}
        <span class="px-2 py-0.5 rounded-full bg-white/5 text-slate-300 text-[10px] mono">
            {% if offer.seniority == 'junior' %}Junior
            {% elseif offer.seniority == 'mid' %}Confirmé
            {% elseif offer.seniority == 'senior' %}Senior
            {% elseif offer.seniority == 'lead' %}Lead{% endif %}
        </span>
        {% endif %}
        {% if offer.remote_policy == 'full_remote' %}
        <span class="px-2 py-0.5 rounded-full bg-cyan-500/20 text-cyan-400 text-[10px] mono">Full remote</span>
        {% elseif offer.remote_policy == 'hybrid' %}
        <span class="px-2 py-0.5 rounded-full bg-amber-500/20 text-amber-400 text-[10px] mono">Hybride</span>
        {% endif %}
        <span class="ml-auto mono text-[11px] text-slate-500">
            #{{ offer.id }} · source {{ offer.source }}{% if offer.posted_at %} · {{ offer.posted_at|ago }}{% endif %}
        </span>
    </div>

    <h1 class="text-3xl sm:text-5xl font-bold tracking-[-0.03em] leading-[1.1] mb-3">{{ offer.title }}</h1>
    <p class="text-xl text-slate-300 mb-2">{{ offer.company_name }}</p>
    <p class="text-sm text-slate-400 mb-6">
        {% if offer.city %}{{ offer.city }}{% if offer.department_code %} ({{ offer.department_code }}){% endif %}{% endif %}
    </p>

    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
        {% if offer.salary_min %}
        <div class="p-4 rounded-2xl bg-white/[0.03] border border-white/5">
            <p class="mono text-[10px] text-slate-500 uppercase tracking-widest mb-1">Rémunération</p>
            <p class="text-2xl font-bold text-emerald-400">
                {{ offer.salary_min|salary }}{% if offer.salary_max and offer.salary_max > offer.salary_min %} – {{ offer.salary_max|salary }}{% endif %}
            </p>
            <p class="text-xs text-slate-500 mono mt-0.5">annuel brut</p>
        </div>
        {% endif %}
        {% if offer.remote_policy %}
        <div class="p-4 rounded-2xl bg-white/[0.03] border border-white/5">
            <p class="mono text-[10px] text-slate-500 uppercase tracking-widest mb-1">Télétravail</p>
            <p class="text-2xl font-bold">
                {% if offer.remote_policy == 'full_remote' %}Full remote
                {% elseif offer.remote_policy == 'hybrid' %}Hybride
                {% elseif offer.remote_policy == 'on_site' %}Sur site
                {% else %}—{% endif %}
            </p>
        </div>
        {% endif %}
        {% if offer.experience_level %}
        <div class="p-4 rounded-2xl bg-white/[0.03] border border-white/5">
            <p class="mono text-[10px] text-slate-500 uppercase tracking-widest mb-1">Expérience</p>
            <p class="text-2xl font-bold">{{ offer.experience_level }}</p>
        </div>
        {% endif %}
    </div>

    {% if offer.source_url %}
    <div class="flex items-center gap-3 mt-6">
        <a href="{{ offer.source_url }}" target="_blank" rel="noopener" class="cta-red px-5 py-2.5 rounded-full font-semibold flex items-center gap-2">
            Postuler sur {{ offer.source|replace({'_': ' '})|title }}
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
        </a>
    </div>
    {% endif %}
</article>

<!-- ─── Salary vs market (progress ring) ─── -->
{% if offer.salary_min and market_salary and market_salary.count > 5 %}
    {% set sal = offer.salary_min %}
    {% set p = 50 %}
    {% if sal <= market_salary.min %}
        {% set p = 0 %}
    {% elseif sal >= market_salary.max %}
        {% set p = 100 %}
    {% elseif sal <= market_salary.p25 %}
        {% set span = (market_salary.p25 - market_salary.min) ?: 1 %}
        {% set p = (sal - market_salary.min) / span * 25 %}
    {% elseif sal <= market_salary.median %}
        {% set span = (market_salary.median - market_salary.p25) ?: 1 %}
        {% set p = 25 + (sal - market_salary.p25) / span * 25 %}
    {% elseif sal <= market_salary.p75 %}
        {% set span = (market_salary.p75 - market_salary.median) ?: 1 %}
        {% set p = 50 + (sal - market_salary.median) / span * 25 %}
    {% else %}
        {% set span = (market_salary.max - market_salary.p75) ?: 1 %}
        {% set p = 75 + (sal - market_salary.p75) / span * 25 %}
    {% endif %}
    {% set p_rounded = p|round %}
    {% set dash = (p * 2.51)|round(2) %}
<section class="reveal glass-strong p-6 sm:p-8 mb-6 relative overflow-hidden" style="animation-delay: 220ms">
    <div class="orb w-48 h-48 bg-red-500/15 -top-10 -left-10"></div>
    <div class="flex items-start gap-6 flex-wrap">
        <div class="relative shrink-0">
            <svg width="140" height="140" viewBox="0 0 100 100" class="-rotate-90">
                <defs>
                    <linearGradient id="salaryGradient" x1="0%" y1="0%" x2="100%" y2="100%">
                        <stop offset="0%" stop-color="#DC2626"/>
                        <stop offset="50%" stop-color="#EC4899"/>
                        <stop offset="100%" stop-color="#22D3EE"/>
                    </linearGradient>
                </defs>
                <circle class="salary-ring-track" cx="50" cy="50" r="40" fill="none" stroke-width="6"/>
                <circle class="salary-ring-fill" cx="50" cy="50" r="40" fill="none" stroke-width="6"
                        stroke-dasharray="0 999" data-target-dash="{{ dash }}"/>
            </svg>
            <div class="absolute inset-0 flex items-center justify-center rotate-0 flex-col">
                <p class="text-3xl font-bold countup" data-countup="{{ p_rounded }}" data-suffix="%">0%</p>
                <p class="mono text-[9px] text-slate-500 uppercase tracking-widest">percentile</p>
            </div>
        </div>
        <div class="flex-1 min-w-[220px]">
            <p class="mono text-[10px] text-slate-400 uppercase tracking-widest mb-1">Positionnement marché</p>
            <h2 class="text-xl font-bold mb-3">
                {% if p_rounded >= 80 %}<span class="gradient-accent">Top {{ 100 - p_rounded }}%</span> du marché
                {% elseif p_rounded >= 60 %}<span class="text-emerald-400">Au-dessus</span> de la médiane
                {% elseif p_rounded >= 40 %}<span class="text-amber-400">Autour</span> de la médiane
                {% else %}<span class="text-slate-300">En dessous</span> de la médiane
                {% endif %}
            </h2>
            <p class="text-sm text-slate-400 mb-4 leading-relaxed">
                Sur {{ market_salary.count }} offres avec salaire, cette offre ({{ sal|salary }}) se situe au percentile <strong class="text-white">{{ p_rounded }}</strong>.
            </p>
            <div class="grid grid-cols-4 gap-2 text-center">
                <div class="p-2 rounded-lg bg-white/[0.03] border border-white/5">
                    <p class="mono text-[9px] text-slate-500 uppercase">P25</p>
                    <p class="text-sm font-semibold">{{ market_salary.p25|salary }}</p>
                </div>
                <div class="p-2 rounded-lg bg-white/[0.03] border border-white/5">
                    <p class="mono text-[9px] text-slate-500 uppercase">Médian</p>
                    <p class="text-sm font-semibold text-pink-400">{{ market_salary.median|salary }}</p>
                </div>
                <div class="p-2 rounded-lg bg-white/[0.03] border border-white/5">
                    <p class="mono text-[9px] text-slate-500 uppercase">P75</p>
                    <p class="text-sm font-semibold">{{ market_salary.p75|salary }}</p>
                </div>
                <div class="p-2 rounded-lg bg-white/[0.03] border border-white/5">
                    <p class="mono text-[9px] text-slate-500 uppercase">Moy.</p>
                    <p class="text-sm font-semibold">{{ market_salary.mean|number_format(0, ',', ' ') }} €</p>
                </div>
            </div>
        </div>
    </div>
    <script>
    (() => {
        const ring = document.querySelector('.salary-ring-fill[data-target-dash]');
        if (!ring) return;
        const target = ring.getAttribute('data-target-dash');
        new IntersectionObserver((entries, obs) => {
            entries.forEach(e => {
                if (e.isIntersecting) {
                    requestAnimationFrame(() => ring.setAttribute('stroke-dasharray', `${target} 999`));
                    obs.unobserve(e.target);
                }
            });
        }, { threshold: 0.4 }).observe(ring);
    })();
    </script>
</section>
{% endif %}

<!-- ─── ML Salary Prediction ─── -->
{% if salary_prediction and salary_prediction.available %}
<section class="reveal glass-strong p-6 mb-6 relative overflow-hidden iridescent" style="animation-delay:260ms">
    <div class="orb w-40 h-40 bg-pink-500/20 -top-5 -right-5"></div>
    <div class="flex items-start gap-4 mb-4">
        <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-pink-500 to-indigo-500 flex items-center justify-center shrink-0">
            <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/></svg>
        </div>
        <div class="flex-1">
            <p class="mono text-[10px] text-pink-400 uppercase tracking-widest">Prédiction ML · scikit-learn</p>
            <h2 class="text-xl font-bold">Fourchette estimée</h2>
        </div>
    </div>
    <p class="text-4xl font-bold gradient-accent mb-2">
        {{ salary_prediction.prediction.low|salary }} – {{ salary_prediction.prediction.high|salary }}
    </p>
    <p class="text-sm text-slate-400 mb-4">
        point estimé : <strong class="text-white">{{ salary_prediction.prediction.point|salary }}</strong>
        · confiance : <strong class="text-pink-400">{{ (salary_prediction.prediction.confidence * 100)|round }}%</strong>
    </p>
    <p class="text-xs text-slate-500 mt-4 pt-4 border-t border-white/5">
        RandomForest entraîné sur <strong class="text-white">{{ salary_prediction.model.training_size }}</strong> offres ·
        <strong class="text-white">{{ salary_prediction.model.feature_count }}</strong> features
        {% if salary_prediction.actual.salary_min %} · salaire annoncé : <strong class="text-emerald-400">{{ salary_prediction.actual.salary_min|salary }}</strong>{% endif %}
    </p>
</section>
{% endif %}

<!-- ─── TECHS ─── -->
{% if offer.technologies|length > 0 %}
<section class="reveal glass-strong p-6 mb-6" style="animation-delay:340ms">
    <p class="mono text-xs text-slate-400 uppercase tracking-widest mb-3">Stack technique · NLP</p>
    <h3 class="text-lg font-bold mb-4">{{ offer.technologies|length }} technologies identifiées</h3>
    <div class="flex flex-wrap gap-2">
        {% for tech in offer.technologies %}
            {% include 'partials/tech_badge.twig' with { tech: tech } %}
        {% endfor %}
    </div>
</section>
{% endif %}

<!-- ─── DESCRIPTION ─── -->
{% if offer.description %}
<section class="reveal glass-strong p-6 sm:p-8 mb-6" style="animation-delay:420ms">
    <h3 class="text-2xl font-bold mb-5">Description du poste</h3>
    <div class="prose-invert-tp body-font leading-relaxed whitespace-pre-wrap">{{ offer.description }}</div>
</section>
{% endif %}

<!-- ─── Offres similaires (TF-IDF) ─── -->
{% if similar_offers|length > 0 %}
<section class="reveal mb-10" style="animation-delay:500ms">
    <div class="flex items-end justify-between mb-5">
        <div>
            <p class="mono text-xs text-slate-400 uppercase tracking-widest mb-1">Similarité sémantique · TF-IDF</p>
            <h2 class="text-2xl font-bold">Offres similaires</h2>
        </div>
        <span class="mono text-xs text-slate-500">cosine sur titre + description</span>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
        {% for s in similar_offers %}
        <a href="/offer.php?id={{ s.id }}" class="block glass-strong p-5 hover:bg-white/[0.06] transition-colors group relative overflow-hidden">
            <div class="flex items-start justify-between gap-3">
                <div class="flex-1">
                    <h3 class="font-semibold mb-1 group-hover:text-red-400 transition-colors line-clamp-2 leading-snug">{{ s.title }}</h3>
                    <p class="text-sm text-slate-400">{{ s.company ?: 'Entreprise anonyme' }}{% if s.city %} · {{ s.city }}{% endif %}</p>
                </div>
                <div class="shrink-0 text-center">
                    <div class="relative w-14 h-14">
                        <svg viewBox="0 0 40 40" class="w-full h-full -rotate-90">
                            <circle cx="20" cy="20" r="16" fill="none" stroke="rgba(255,255,255,0.06)" stroke-width="3"/>
                            <circle cx="20" cy="20" r="16" fill="none" stroke="#EC4899" stroke-width="3" stroke-dasharray="{{ (s.score * 100)|round }} 100"/>
                        </svg>
                        <div class="absolute inset-0 flex items-center justify-center">
                            <span class="text-xs font-bold rotate-0">{{ (s.score * 100)|round }}%</span>
                        </div>
                    </div>
                    <span class="mono text-[9px] text-pink-400 uppercase">similar</span>
                </div>
            </div>
        </a>
        {% endfor %}
    </div>
</section>
{% endif %}

</div>

{% endblock %}
