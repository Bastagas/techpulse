{% extends 'layout.twig' %}
{% set active_page = 'about' %}
{% block title %}À propos{% endblock %}

{% block content %}

<div class="max-w-4xl mx-auto">

<!-- ─── HERO ─── -->
<section class="reveal mb-10 relative" style="animation-delay:120ms">
    <p class="mono text-xs text-slate-400 uppercase tracking-widest mb-2">Manifesto · Open-source</p>
    <h1 class="text-5xl sm:text-6xl font-bold tracking-[-0.04em] leading-[1.02] mb-5">
        Un observatoire <span class="gradient-accent">honnête</span> du marché tech.
    </h1>
    <p class="text-lg text-slate-300 leading-relaxed max-w-3xl">
        TechPulse est un observatoire open-source du marché de l'emploi tech en France.
        Projet réalisé dans le cadre du cours de <strong class="text-white">Web Scraping</strong> du Master 2
        à l'Université de Montpellier.
    </p>
</section>

<!-- ─── FONCTIONNEMENT ─── -->
<section class="reveal glass-strong p-6 sm:p-8 mb-6 relative overflow-hidden" style="animation-delay:200ms">
    <div class="orb w-60 h-60 bg-indigo-500/15 -top-10 -right-10"></div>
    <div class="flex items-center gap-3 mb-4">
        <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-red-500 to-pink-500 flex items-center justify-center shrink-0">
            <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
        </div>
        <div>
            <p class="mono text-[10px] text-slate-400 uppercase tracking-widest">Pipeline</p>
            <h2 class="text-2xl font-bold">Fonctionnement</h2>
        </div>
    </div>
    <p class="text-slate-300 leading-relaxed">
        Un pipeline Python asynchrone agrège en continu les offres publiées sur l'API officielle
        <strong class="text-white">France Travail</strong> (anciennement Pôle Emploi) et, à terme, HelloWork et APEC.
        Un référentiel canonique de <strong class="text-white">202 technologies</strong> (langages, frameworks, bases de données, cloud…)
        permet d'extraire les stacks demandées via une approche hybride <strong class="text-cyan-400">regex + NLP</strong>.
    </p>
</section>

<!-- ─── STATS LIVE ─── -->
<section class="reveal mb-6" style="animation-delay:280ms">
    <div class="flex items-end justify-between mb-4">
        <div>
            <p class="mono text-xs text-slate-400 uppercase tracking-widest mb-1">Statistiques en direct</p>
            <h2 class="text-2xl font-bold">Stats live</h2>
        </div>
        <span class="mono text-xs text-slate-500">màj continue</span>
    </div>
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-3">
        <div class="reveal-io glass-strong p-5 relative overflow-hidden iridescent" style="--reveal-delay: 40ms">
            <p class="mono text-[10px] text-slate-500 uppercase tracking-widest mb-2">Offres actives</p>
            <p class="text-3xl font-bold gradient-accent countup" data-countup="{{ stats.total }}">0</p>
        </div>
        <div class="reveal-io glass-strong p-5" style="--reveal-delay: 90ms">
            <p class="mono text-[10px] text-slate-500 uppercase tracking-widest mb-2">Entreprises</p>
            <p class="text-3xl font-bold text-white countup" data-countup="{{ stats.companies }}">0</p>
        </div>
        <div class="reveal-io glass-strong p-5" style="--reveal-delay: 140ms">
            <p class="mono text-[10px] text-slate-500 uppercase tracking-widest mb-2">Villes couvertes</p>
            <p class="text-3xl font-bold text-white countup" data-countup="{{ stats.cities }}">0</p>
        </div>
        <div class="reveal-io glass-strong p-5" style="--reveal-delay: 190ms">
            <p class="mono text-[10px] text-slate-500 uppercase tracking-widest mb-2">Avec salaire</p>
            <p class="text-3xl font-bold text-emerald-400 countup" data-countup="{{ stats.with_salary }}">0</p>
        </div>
    </div>
    {% if stats.last_scraped %}
    <p class="mono text-xs text-slate-500 mt-3">
        Dernière actualisation : <span class="text-slate-300">{{ stats.last_scraped|ago }}</span>
    </p>
    {% endif %}
</section>

<!-- ─── ÉTHIQUE ─── -->
<section class="reveal glass-strong p-6 sm:p-8 mb-6 relative overflow-hidden" style="animation-delay:360ms">
    <div class="orb w-60 h-60 bg-emerald-500/15 -top-10 -left-10"></div>
    <div class="flex items-center gap-3 mb-5">
        <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-emerald-500 to-cyan-500 flex items-center justify-center shrink-0">
            <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
        </div>
        <div>
            <p class="mono text-[10px] text-slate-400 uppercase tracking-widest">Charte</p>
            <h2 class="text-2xl font-bold">Éthique du scraping</h2>
        </div>
    </div>
    <ul class="space-y-3">
        <li class="flex items-start gap-3">
            <div class="w-1.5 h-1.5 rounded-full bg-emerald-400 mt-2 shrink-0"></div>
            <span class="text-slate-300 leading-relaxed">Respect systématique du <code class="mono text-xs px-1.5 py-0.5 rounded bg-white/5 text-cyan-300">robots.txt</code>.</span>
        </li>
        <li class="flex items-start gap-3">
            <div class="w-1.5 h-1.5 rounded-full bg-emerald-400 mt-2 shrink-0"></div>
            <span class="text-slate-300 leading-relaxed">Rate limiting respectueux (<strong class="text-white">1 req / 2 s</strong> par domaine, configurable).</span>
        </li>
        <li class="flex items-start gap-3">
            <div class="w-1.5 h-1.5 rounded-full bg-emerald-400 mt-2 shrink-0"></div>
            <span class="text-slate-300 leading-relaxed">Usage privilégié des APIs officielles quand disponibles (<strong class="text-white">France Travail</strong>).</span>
        </li>
        <li class="flex items-start gap-3">
            <div class="w-1.5 h-1.5 rounded-full bg-emerald-400 mt-2 shrink-0"></div>
            <span class="text-slate-300 leading-relaxed">Données <strong class="text-white">publiques uniquement</strong>, pas de contournement de CAPTCHA.</span>
        </li>
    </ul>
</section>

<!-- ─── STACK TECHNIQUE ─── -->
<section class="reveal glass-strong p-6 sm:p-8 mb-6" style="animation-delay:440ms">
    <p class="mono text-xs text-slate-400 uppercase tracking-widest mb-2">Stack technique</p>
    <h2 class="text-2xl font-bold mb-5">Technologies utilisées</h2>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-5">
        <div class="p-4 rounded-2xl bg-white/[0.03] border border-white/5">
            <p class="mono text-[10px] text-red-400 uppercase tracking-widest mb-2">Backend · Python</p>
            <div class="flex flex-wrap gap-1">
                <span class="text-[11px] font-medium px-2 py-0.5 rounded-full bg-red-500/15 border border-red-500/25 text-red-300">Python 3.11</span>
                <span class="text-[11px] font-medium px-2 py-0.5 rounded-full bg-red-500/15 border border-red-500/25 text-red-300">httpx async</span>
                <span class="text-[11px] font-medium px-2 py-0.5 rounded-full bg-purple-500/15 border border-purple-500/25 text-purple-300">SQLAlchemy 2</span>
                <span class="text-[11px] font-medium px-2 py-0.5 rounded-full bg-purple-500/15 border border-purple-500/25 text-purple-300">Pydantic v2</span>
                <span class="text-[11px] font-medium px-2 py-0.5 rounded-full bg-purple-500/15 border border-purple-500/25 text-purple-300">Flask + smorest</span>
            </div>
        </div>
        <div class="p-4 rounded-2xl bg-white/[0.03] border border-white/5">
            <p class="mono text-[10px] text-cyan-400 uppercase tracking-widest mb-2">Frontend · PHP</p>
            <div class="flex flex-wrap gap-1">
                <span class="text-[11px] font-medium px-2 py-0.5 rounded-full bg-red-500/15 border border-red-500/25 text-red-300">PHP 8</span>
                <span class="text-[11px] font-medium px-2 py-0.5 rounded-full bg-purple-500/15 border border-purple-500/25 text-purple-300">Twig</span>
                <span class="text-[11px] font-medium px-2 py-0.5 rounded-full bg-cyan-500/15 border border-cyan-500/25 text-cyan-300">Tailwind CSS</span>
                <span class="text-[11px] font-medium px-2 py-0.5 rounded-full bg-indigo-500/15 border border-indigo-500/25 text-indigo-300">Alpine.js</span>
                <span class="text-[11px] font-medium px-2 py-0.5 rounded-full bg-indigo-500/15 border border-indigo-500/25 text-indigo-300">Chart.js</span>
            </div>
        </div>
        <div class="p-4 rounded-2xl bg-white/[0.03] border border-white/5">
            <p class="mono text-[10px] text-pink-400 uppercase tracking-widest mb-2">Infra · DevOps</p>
            <div class="flex flex-wrap gap-1">
                <span class="text-[11px] font-medium px-2 py-0.5 rounded-full bg-pink-500/15 border border-pink-500/25 text-pink-300">Docker</span>
                <span class="text-[11px] font-medium px-2 py-0.5 rounded-full bg-pink-500/15 border border-pink-500/25 text-pink-300">MySQL 8</span>
                <span class="text-[11px] font-medium px-2 py-0.5 rounded-full bg-amber-500/15 border border-amber-500/25 text-amber-300">GitHub Actions</span>
                <span class="text-[11px] font-medium px-2 py-0.5 rounded-full bg-amber-500/15 border border-amber-500/25 text-amber-300">Cloudflare Tunnel</span>
            </div>
        </div>
    </div>

    <div class="pt-5 border-t border-white/5 flex flex-wrap items-center gap-3">
        <span class="mono text-xs text-slate-500 uppercase tracking-widest">Code source</span>
        <a href="https://github.com/Bastagas/techpulse" target="_blank" rel="noopener"
           class="inline-flex items-center gap-2 px-4 py-2 rounded-full pill text-sm text-white">
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.477 2 2 6.477 2 12c0 4.418 2.865 8.166 6.839 9.489.5.092.682-.217.682-.482 0-.237-.008-.866-.013-1.7-2.782.603-3.369-1.342-3.369-1.342-.454-1.155-1.11-1.462-1.11-1.462-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.087 2.91.831.092-.646.35-1.086.636-1.336-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.025A9.567 9.567 0 0112 6.82c.85.004 1.705.114 2.504.336 1.909-1.295 2.748-1.025 2.748-1.025.546 1.378.202 2.397.1 2.65.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.743 0 .267.18.578.688.48C19.137 20.163 22 16.417 22 12c0-5.523-4.477-10-10-10z"/></svg>
            github.com/Bastagas/techpulse
        </a>
    </div>
</section>

</div>

{% endblock %}
