{# ─── Barre flottante comparateur ─── #}
<div id="compare-bar" class="fixed bottom-6 left-1/2 -translate-x-1/2 z-40 hidden pointer-events-none">
    <div class="glass-strong iridescent pointer-events-auto px-4 py-2.5 rounded-full flex items-center gap-3 shadow-2xl">
        <div class="w-8 h-8 rounded-full bg-gradient-to-br from-red-500 via-pink-500 to-indigo-500 flex items-center justify-center mono text-xs font-bold text-white">
            <span id="compare-count">0</span>
        </div>
        <span class="text-sm text-slate-200">offre<span id="compare-plural"></span> sélectionnée<span id="compare-plural2"></span></span>
        <span class="mono text-[10px] text-slate-500 uppercase tracking-widest">· max 4</span>
        <button id="compare-go" class="cta-red px-4 py-1.5 rounded-full text-white text-sm font-semibold inline-flex items-center gap-1.5">
            Comparer
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"/></svg>
        </button>
        <button id="compare-clear" class="w-7 h-7 rounded-full bg-white/5 hover:bg-white/10 text-slate-400 hover:text-white flex items-center justify-center transition-colors" title="Tout désélectionner">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 18L18 6M6 6l12 12"/></svg>
        </button>
    </div>
</div>

<script>
(() => {
    const STORE = 'techpulse_compare';
    const getIds = () => JSON.parse(localStorage.getItem(STORE) || '[]');
    const setIds = (ids) => localStorage.setItem(STORE, JSON.stringify(ids));
    const bar = document.getElementById('compare-bar');
    const countEl = document.getElementById('compare-count');
    const plural1 = document.getElementById('compare-plural');
    const plural2 = document.getElementById('compare-plural2');

    function refresh() {
        const ids = getIds();
        if (ids.length > 0) {
            bar.classList.remove('hidden');
            countEl.textContent = ids.length;
            const s = ids.length > 1 ? 's' : '';
            plural1.textContent = s;
            plural2.textContent = s;
        } else {
            bar.classList.add('hidden');
        }
        document.querySelectorAll('.compare-checkbox').forEach(cb => {
            cb.checked = ids.includes(parseInt(cb.dataset.offerId));
        });
    }

    document.addEventListener('click', (e) => {
        const cb = e.target.closest('.compare-checkbox');
        if (cb) {
            e.stopPropagation();
            const id = parseInt(cb.dataset.offerId);
            let ids = getIds();
            if (cb.checked) {
                if (ids.length >= 4) {
                    alert('Maximum 4 offres pour la comparaison.');
                    cb.checked = false;
                    return;
                }
                if (!ids.includes(id)) ids.push(id);
            } else {
                ids = ids.filter(x => x !== id);
            }
            setIds(ids);
            refresh();
            return;
        }
        // Bloque le clic sur le label d'ajout au comparateur (évite navigation vers l'offre)
        const lbl = e.target.closest('label[title="Ajouter au comparateur"]');
        if (lbl) {
            e.stopPropagation();
        }
    }, true);

    document.getElementById('compare-go')?.addEventListener('click', () => {
        const ids = getIds();
        if (ids.length < 2) {
            alert('Sélectionne au moins 2 offres.');
            return;
        }
        window.location = '/compare.php?ids=' + ids.join(',');
    });

    document.getElementById('compare-clear')?.addEventListener('click', () => {
        setIds([]);
        refresh();
    });

    document.addEventListener('DOMContentLoaded', refresh);
    refresh();
})();
</script>

{# ─── Command palette (⌘K) ─── #}
<div x-data="cmdk" x-show="open" x-cloak @keydown.window.prevent.meta.k="toggle()" @keydown.window.prevent.ctrl.k="toggle()" @keydown.escape.window="close()" style="display:none;">
    <div class="cmdk-backdrop" @click="close()" x-transition.opacity></div>
    <div class="cmdk-modal glass-strong iridescent" @click.stop>
        <div class="flex items-center border-b border-white/5">
            <svg class="w-5 h-5 text-slate-500 ml-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
            <input x-ref="input" x-model="q" @input.debounce.180ms="search()" @keydown.down.prevent="move(1)" @keydown.up.prevent="move(-1)" @keydown.enter.prevent="run()" placeholder="Rechercher une offre, une techno, une page…" class="cmdk-input" autocomplete="off" spellcheck="false" />
            <span class="cmdk-kbd mr-4">ESC</span>
        </div>
        <div class="max-h-[52vh] overflow-y-auto pb-3">
            <template x-if="groups.length === 0 && q.length > 0 && !loading">
                <p class="text-sm text-slate-500 px-5 py-8 text-center">Aucun résultat pour « <span class="text-slate-300" x-text="q"></span> »</p>
            </template>
            <template x-for="(group, gi) in groups" :key="gi">
                <div>
                    <p class="cmdk-group-label" x-text="group.label"></p>
                    <template x-for="(hit, hi) in group.items" :key="group.label + hi">
                        <a :href="hit.href" class="cmdk-hit" :class="{ 'active': active === group.offset + hi }" @mouseenter="active = group.offset + hi">
                            <span class="cmdk-hit-icon" x-html="hit.icon"></span>
                            <div class="flex-1 min-w-0">
                                <p class="text-sm text-slate-100 truncate" x-text="hit.title"></p>
                                <p class="text-xs text-slate-500 truncate" x-show="hit.subtitle" x-text="hit.subtitle"></p>
                            </div>
                            <span class="mono text-[10px] text-slate-500" x-text="hit.badge"></span>
                        </a>
                    </template>
                </div>
            </template>
        </div>
        <div class="flex items-center justify-between border-t border-white/5 px-5 py-2 text-[11px] text-slate-500 mono">
            <span>↑↓ naviguer · ⏎ ouvrir</span>
            <span>TechPulse · ⌘K</span>
        </div>
    </div>
</div>

