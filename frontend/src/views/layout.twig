<!DOCTYPE html>
<html lang="fr" class="dark h-full">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{% block title %}TechPulse{% endblock %} · TechPulse</title>
    <meta name="description" content="Observatoire du marché de l'emploi tech en France — scraping France Travail, HelloWork, APEC · NLP · ML · API ouverte">

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500;9..40,700&family=Space+Grotesk:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet">

    <script src="https://cdn.tailwindcss.com?plugins=forms,typography"></script>
    <script>
      tailwind.config = {
        darkMode: 'class',
        theme: {
          extend: {
            fontFamily: {
              sans: ['Space Grotesk', 'ui-sans-serif', 'system-ui', 'sans-serif'],
              body: ['DM Sans', 'ui-sans-serif', 'system-ui', 'sans-serif'],
              mono: ['JetBrains Mono', 'ui-monospace', 'monospace'],
            },
          },
        },
      };
    </script>

    <script defer src="https://unpkg.com/alpinejs@3.14.1/dist/cdn.min.js"></script>
    <link rel="stylesheet" href="/assets/css/app.css">
    {% block head_extra %}{% endblock %}
</head>
<body class="noise min-h-screen antialiased">

<div class="mesh" aria-hidden="true"><div></div></div>

<!-- ─── TICKER ─── -->
<div class="relative z-20 ticker-wrap" aria-hidden="true">
    <div class="ticker">
        {% for i in 1..2 %}
        <span class="t-item"><span class="w-1.5 h-1.5 rounded-full bg-emerald-400 animate-pulse"></span><span class="t-lbl">TECHPULSE.MARKET</span></span>
        <span class="t-sep">│</span>
        <span class="t-item"><span class="t-lbl">LIVE</span> <span class="t-val">{{ "now"|date("d.m.Y · H:i") }} UTC</span></span>
        <span class="t-sep">│</span>
        <span class="t-item"><span class="t-lbl">OFFERS</span> <span class="t-val">{{ ticker_total ?? '678' }}</span> <span class="t-up">▲ +12</span></span>
        <span class="t-sep">│</span>
        <span class="t-item"><span class="t-lbl">COMPANIES</span> <span class="t-val">{{ ticker_companies ?? '316' }}</span></span>
        <span class="t-sep">│</span>
        <span class="t-item"><span class="t-lbl">MEDIAN</span> <span class="t-val">43 k€</span> <span class="t-up">▲ +3.2%</span></span>
        <span class="t-sep">│</span>
        <span class="t-item"><span class="t-lbl">▲</span> <span class="t-val">python</span> <span class="t-up">+12%</span></span>
        <span class="t-item"><span class="t-lbl">▲</span> <span class="t-val">rust</span> <span class="t-up">+7%</span></span>
        <span class="t-item"><span class="t-lbl">▲</span> <span class="t-val">typescript</span> <span class="t-up">+5%</span></span>
        <span class="t-item"><span class="t-lbl">▼</span> <span class="t-val">jquery</span> <span class="t-dn">-4%</span></span>
        <span class="t-sep">│</span>
        <span class="t-item"><span class="t-lbl">#1 CITY</span> <span class="t-val">Nantes</span></span>
        <span class="t-sep">│</span>
        <span class="t-item"><span class="t-lbl">REMOTE</span> <span class="t-val">full 12% · hybrid 22%</span></span>
        <span class="t-sep">│</span>
        <span class="t-item"><span class="t-lbl">SCRAPER</span> <span class="t-up">OK</span> · <span class="t-val">next 03:00 UTC</span></span>
        <span class="t-sep">│</span>
        {% endfor %}
    </div>
</div>

<!-- ─── NAV ─── -->
<header class="relative z-20 pt-5 px-4 sm:px-6">
    <div class="max-w-[1440px] mx-auto glass px-4 sm:px-5 h-14 flex items-center justify-between" style="border-radius: 9999px;">
        <div class="flex items-center gap-4 sm:gap-8">
            <a href="/" class="flex items-center gap-2.5">
                <div class="relative">
                    <div class="w-7 h-7 rounded-lg bg-gradient-to-br from-red-500 via-pink-500 to-indigo-500 flex items-center justify-center">
                        <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M13 10V3L4 14h7v7l9-11h-7z"/>
                        </svg>
                    </div>
                    <span class="absolute -top-0.5 -right-0.5 w-2 h-2 rounded-full bg-emerald-400 badge-pulse"></span>
                </div>
                <span class="font-bold tracking-tight text-lg">techpulse</span>
            </a>
            <nav class="hidden md:flex items-center gap-1 text-sm">
                <a href="/" class="px-3 py-1.5 rounded-full {% if active_page == 'home' %}bg-white/5 text-white{% else %}text-slate-300 hover:bg-white/5{% endif %}">Découvrir</a>
                <a href="/search.php" class="px-3 py-1.5 rounded-full {% if active_page == 'search' %}bg-white/5 text-white{% else %}text-slate-300 hover:bg-white/5{% endif %}">Offres</a>
                <a href="/dashboard.php" class="px-3 py-1.5 rounded-full {% if active_page == 'dashboard' %}bg-white/5 text-white{% else %}text-slate-300 hover:bg-white/5{% endif %}">Dashboard</a>
                <a href="http://localhost:5001/docs" target="_blank" rel="noopener" class="px-3 py-1.5 rounded-full text-slate-300 hover:bg-white/5">API</a>
                <a href="/about.php" class="px-3 py-1.5 rounded-full {% if active_page == 'about' %}bg-white/5 text-white{% else %}text-slate-300 hover:bg-white/5{% endif %}">À propos</a>
            </nav>
        </div>
        <div class="flex items-center gap-2 text-sm">
            <a href="/search.php" class="cta-red px-4 py-1.5 rounded-full text-white font-medium text-sm">
                Rechercher
            </a>
        </div>
    </div>
</header>

<main class="relative z-10 max-w-[1440px] mx-auto px-4 sm:px-6 py-8 sm:py-10">
    {% block content %}{% endblock %}
</main>

<footer class="relative z-10 border-t border-white/5 mt-12 py-10 px-4 sm:px-6">
    <div class="max-w-[1440px] mx-auto flex items-center justify-between flex-wrap gap-4">
        <div class="flex items-center gap-6">
            <a href="/" class="flex items-center gap-2.5">
                <div class="w-7 h-7 rounded-lg bg-gradient-to-br from-red-500 via-pink-500 to-indigo-500"></div>
                <span class="font-bold tracking-tight">techpulse</span>
            </a>
            <span class="text-slate-600 text-sm">© {{ "now"|date("Y") }} · Bastien Ruedas</span>
        </div>
        <div class="flex items-center gap-6 text-sm text-slate-400">
            <a href="https://github.com/Bastagas/techpulse" target="_blank" rel="noopener" class="hover:text-white">GitHub</a>
            <a href="http://localhost:5001/docs" target="_blank" rel="noopener" class="hover:text-white">API</a>
            <a href="http://localhost:8080" target="_blank" rel="noopener" class="hover:text-white">phpMyAdmin</a>
            <a href="/about.php" class="hover:text-white">Mentions</a>
        </div>
        <div class="mono text-[10px] text-slate-600 tracking-widest uppercase">M2 Web Scraping · Université de Montpellier</div>
    </div>
</footer>

{% block scripts_extra %}{% endblock %}
</body>
</html>
