<!DOCTYPE html>
<html lang="fr" class="h-full">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{% block title %}TechPulse{% endblock %} · TechPulse</title>
    <meta name="description" content="Observatoire du marché de l'emploi tech en France — scraping en continu de France Travail, HelloWork et APEC">

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">

    <script src="https://cdn.tailwindcss.com?plugins=forms,typography"></script>
    <script>
      tailwind.config = {
        darkMode: 'class',
        theme: {
          extend: {
            fontFamily: {
              sans: ['Inter', 'ui-sans-serif', 'system-ui', 'sans-serif'],
              mono: ['JetBrains Mono', 'ui-monospace', 'monospace'],
            },
            colors: {
              brand: {
                50: '#eff6ff', 100: '#dbeafe', 200: '#bfdbfe', 300: '#93c5fd',
                400: '#60a5fa', 500: '#3b82f6', 600: '#2563eb', 700: '#1d4ed8',
                800: '#1e40af', 900: '#1e3a8a', 950: '#172554',
              },
            },
          },
        },
      };
      // Mode sombre persistant avant rendu pour éviter flash
      if (localStorage.getItem('theme') === 'dark' || (!('theme' in localStorage) && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
        document.documentElement.classList.add('dark');
      }
    </script>

    <script defer src="https://unpkg.com/alpinejs@3.14.1/dist/cdn.min.js"></script>
    <link rel="stylesheet" href="/assets/css/app.css">
</head>
<body class="h-full bg-gray-50 dark:bg-gray-950 text-gray-900 dark:text-gray-100 font-sans antialiased">

<header class="sticky top-0 z-30 border-b border-gray-200/70 dark:border-gray-800 bg-white/80 dark:bg-gray-950/80 backdrop-blur">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="flex h-16 items-center justify-between">
            <a href="/" class="flex items-center gap-2">
                <div class="h-8 w-8 rounded-lg bg-gradient-to-br from-brand-500 to-brand-700 flex items-center justify-center">
                    <svg class="h-5 w-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M13 10V3L4 14h7v7l9-11h-7z"/>
                    </svg>
                </div>
                <span class="font-bold text-lg">TechPulse</span>
            </a>

            <nav class="flex items-center gap-1 sm:gap-3">
                <a href="/" class="px-3 py-2 rounded-md text-sm font-medium hover:bg-gray-100 dark:hover:bg-gray-800">
                    Accueil
                </a>
                <a href="/search.php" class="px-3 py-2 rounded-md text-sm font-medium hover:bg-gray-100 dark:hover:bg-gray-800">
                    Recherche
                </a>
                <a href="/dashboard.php" class="px-3 py-2 rounded-md text-sm font-medium hover:bg-gray-100 dark:hover:bg-gray-800">
                    Dashboard
                </a>
                <a href="/about.php" class="hidden sm:inline-block px-3 py-2 rounded-md text-sm font-medium hover:bg-gray-100 dark:hover:bg-gray-800">
                    À propos
                </a>

                <button
                    type="button"
                    onclick="document.documentElement.classList.toggle('dark'); localStorage.setItem('theme', document.documentElement.classList.contains('dark') ? 'dark' : 'light');"
                    class="p-2 rounded-md hover:bg-gray-100 dark:hover:bg-gray-800"
                    aria-label="Changer de thème">
                    <svg class="h-5 w-5 hidden dark:inline" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"/>
                    </svg>
                    <svg class="h-5 w-5 dark:hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"/>
                    </svg>
                </button>
            </nav>
        </div>
    </div>
</header>

<main class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-8 sm:py-12">
    {% block content %}{% endblock %}
</main>

{# ─── Barre flottante comparateur ─── #}
<div id="compare-bar" class="fixed bottom-6 left-1/2 -translate-x-1/2 z-40 hidden"
     style="min-width: 280px;">
    <div class="bg-brand-600 text-white rounded-full shadow-xl px-5 py-3 flex items-center gap-4">
        <span class="text-sm font-medium"><span id="compare-count">0</span> offre(s) sélectionnée(s)</span>
        <button id="compare-go" class="bg-white text-brand-600 px-3 py-1 rounded-full text-sm font-semibold hover:bg-gray-100">
            Comparer →
        </button>
        <button id="compare-clear" class="text-white/80 hover:text-white text-sm">✕</button>
    </div>
</div>

<script>
(() => {
    const STORE = 'techpulse_compare';
    const getIds = () => JSON.parse(localStorage.getItem(STORE) || '[]');
    const setIds = (ids) => localStorage.setItem(STORE, JSON.stringify(ids));
    const bar = document.getElementById('compare-bar');
    const count = document.getElementById('compare-count');

    function refresh() {
        const ids = getIds();
        if (ids.length > 0) {
            bar.classList.remove('hidden');
            count.textContent = ids.length;
        } else {
            bar.classList.add('hidden');
        }
        // Cocher automatiquement les checkboxes déjà dans la liste
        document.querySelectorAll('.compare-checkbox').forEach(cb => {
            cb.checked = ids.includes(parseInt(cb.dataset.offerId));
        });
    }

    document.addEventListener('click', (e) => {
        if (e.target.classList.contains('compare-checkbox')) {
            e.stopPropagation();
            const id = parseInt(e.target.dataset.offerId);
            let ids = getIds();
            if (e.target.checked) {
                if (ids.length >= 4) {
                    alert('Maximum 4 offres pour la comparaison.');
                    e.target.checked = false;
                    return;
                }
                if (!ids.includes(id)) ids.push(id);
            } else {
                ids = ids.filter(x => x !== id);
            }
            setIds(ids);
            refresh();
        }
    });

    // Empêche le clic sur la checkbox de déclencher le lien parent
    document.addEventListener('click', (e) => {
        if (e.target.closest('label') && e.target.closest('.compare-checkbox, label')) {
            e.stopPropagation();
        }
    }, true);

    document.getElementById('compare-go')?.addEventListener('click', () => {
        const ids = getIds();
        if (ids.length < 2) {
            alert('Sélectionne au moins 2 offres.');
            return;
        }
        window.location = '/compare.php?ids=' + ids.join(',');
    });

    document.getElementById('compare-clear')?.addEventListener('click', () => {
        setIds([]);
        refresh();
    });

    document.addEventListener('DOMContentLoaded', refresh);
    refresh();
})();
</script>

<footer class="mt-16 border-t border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-950">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-8 text-sm text-gray-600 dark:text-gray-400">
        <div class="flex flex-col sm:flex-row gap-4 justify-between items-start">
            <div>
                <p class="font-semibold text-gray-900 dark:text-gray-100">TechPulse</p>
                <p class="mt-1">Observatoire du marché emploi tech en France · Projet M2, Université de Montpellier</p>
            </div>
            <div class="flex gap-4">
                <a href="https://github.com/Bastagas/techpulse" class="hover:text-gray-900 dark:hover:text-gray-100" target="_blank" rel="noopener">GitHub</a>
                <a href="http://localhost:5001/docs" class="hover:text-gray-900 dark:hover:text-gray-100" target="_blank" rel="noopener">API</a>
                <a href="http://localhost:8080" class="hover:text-gray-900 dark:hover:text-gray-100" target="_blank" rel="noopener">phpMyAdmin</a>
            </div>
        </div>
    </div>
</footer>

</body>
</html>
