{% extends 'layout.twig' %}
{% set active_page = 'simulator' %}
{% block title %}Simulateur salaire{% endblock %}

{% block content %}

<div class="max-w-5xl mx-auto">

<!-- ─── HERO ─── -->
<section class="reveal mb-10" style="animation-delay:100ms">
    <p class="mono text-xs text-slate-400 uppercase tracking-widest mb-2">Prédiction · scikit-learn</p>
    <h1 class="text-5xl sm:text-6xl font-bold tracking-[-0.04em] leading-[1.02] mb-4">
        Ton salaire, <span class="gradient-accent italic">estimé par un modèle.</span>
    </h1>
    <p class="text-lg text-slate-300 leading-relaxed max-w-3xl body-font">
        Décris ton profil et le RandomForest entraîné sur <strong class="text-white">1 214 offres</strong> du marché
        te rend une fourchette P25–P75 avec indice de confiance. 100% local, aucun envoi externe.
    </p>
</section>

<div x-data="simulatorForm()" class="reveal grid grid-cols-1 lg:grid-cols-5 gap-6" style="animation-delay:200ms">

    <!-- ─── FORM ─── -->
    <section class="lg:col-span-3 glass-strong p-6 sm:p-8 relative overflow-hidden">
        <div class="orb w-56 h-56 bg-indigo-500/15 -top-10 -right-10"></div>

        <p class="mono text-xs text-slate-400 uppercase tracking-widest mb-2">Profil</p>
        <h2 class="text-2xl font-bold mb-6">Décris-toi</h2>

        <div class="space-y-5">
            <!-- Ville -->
            <div>
                <label class="mono text-[10px] text-slate-400 uppercase tracking-widest mb-1.5 block">Ville</label>
                <input x-model="form.city" list="cities-dl" class="input-field" placeholder="Paris, Nantes, Toulouse…" />
                <datalist id="cities-dl">
                    {% for c in cities|slice(0, 100) %}
                    <option value="{{ c }}"></option>
                    {% endfor %}
                </datalist>
            </div>

            <!-- Département + Contrat -->
            <div class="grid grid-cols-2 gap-3">
                <div>
                    <label class="mono text-[10px] text-slate-400 uppercase tracking-widest mb-1.5 block">Département</label>
                    <input x-model="form.department" class="input-field" placeholder="75, 44, 31…" maxlength="3" />
                </div>
                <div>
                    <label class="mono text-[10px] text-slate-400 uppercase tracking-widest mb-1.5 block">Contrat</label>
                    <select x-model="form.contract" class="input-field">
                        <option value="">—</option>
                        {% for ct in contracts %}
                        <option value="{{ ct }}">{{ ct }}</option>
                        {% endfor %}
                    </select>
                </div>
            </div>

            <!-- Expérience -->
            <div>
                <label class="mono text-[10px] text-slate-400 uppercase tracking-widest mb-1.5 block">Expérience</label>
                <select x-model="form.experience" class="input-field">
                    <option value="Débutant accepté">Débutant accepté</option>
                    <option value="1 An(s)">1 an</option>
                    <option value="2 An(s)">2 ans</option>
                    <option value="3 An(s)">3 ans</option>
                    <option value="5 An(s)">5 ans</option>
                    <option value="10 An(s)">10 ans et +</option>
                </select>
            </div>

            <!-- Techs -->
            <div>
                <label class="mono text-[10px] text-slate-400 uppercase tracking-widest mb-1.5 block">
                    Technologies <span class="text-slate-500 normal-case">(clique pour ajouter / retirer, max 10)</span>
                </label>
                <div class="flex flex-wrap gap-1.5 p-3 rounded-xl bg-white/[0.03] border border-white/5 min-h-[80px]">
                    {% for t in top_techs|slice(0, 40) %}
                    <button type="button"
                            @click="toggleTech('{{ t.canonical_name }}')"
                            :class="form.technologies.includes('{{ t.canonical_name }}') ? 'bg-red-500/25 border-red-400/60 text-red-200' : 'bg-white/5 border-white/10 text-slate-300 hover:bg-white/10'"
                            class="px-2.5 py-1 text-[11px] font-medium rounded-full border transition-all">
                        {{ t.display_name }}<span class="text-[9px] text-slate-500 mono ml-1">{{ t.count }}</span>
                    </button>
                    {% endfor %}
                </div>
                <p class="mt-1.5 text-xs text-slate-500 mono" x-show="form.technologies.length > 0">
                    <span x-text="form.technologies.length"></span>/10 sélectionnées · <span x-text="form.technologies.join(', ')"></span>
                </p>
            </div>

            <!-- Submit -->
            <button type="button" @click="simulate()" :disabled="loading"
                    class="cta-red w-full px-5 py-3 rounded-full font-semibold inline-flex items-center justify-center gap-2 disabled:opacity-60">
                <template x-if="!loading">
                    <span class="inline-flex items-center gap-2">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
                        Prédire mon salaire
                    </span>
                </template>
                <template x-if="loading">
                    <span class="inline-flex items-center gap-2">
                        <svg class="w-4 h-4 animate-spin" fill="none" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="3" opacity="0.25"/><path fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"/></svg>
                        Calcul en cours…
                    </span>
                </template>
            </button>
        </div>
    </section>

    <!-- ─── RESULT ─── -->
    <section class="lg:col-span-2 space-y-4">
        <div class="glass-strong p-6 relative overflow-hidden iridescent min-h-[280px]" :class="result ? '' : 'opacity-70'">
            <div class="orb w-48 h-48 bg-red-500/25 -top-10 -right-10"></div>
            <p class="mono text-xs text-slate-400 uppercase tracking-widest mb-2">Résultat</p>

            <template x-if="!result && !error">
                <div class="pt-8 pb-4 text-slate-500">
                    <svg class="w-12 h-12 mb-4 text-slate-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>
                    <p class="text-sm">Renseigne un profil à gauche puis clique sur <strong class="text-slate-300">Prédire</strong>.</p>
                </div>
            </template>

            <template x-if="error">
                <div class="pt-4 text-red-400">
                    <p class="text-sm" x-text="error"></p>
                </div>
            </template>

            <template x-if="result && result.available">
                <div>
                    <p class="mono text-[10px] text-slate-400 uppercase tracking-widest">Fourchette estimée</p>
                    <p class="text-4xl font-bold gradient-accent leading-tight mb-1" x-text="`${fmtK(result.prediction.low)} – ${fmtK(result.prediction.high)}`"></p>
                    <p class="text-sm text-slate-400 mb-4">
                        point estimé : <strong class="text-white" x-text="fmtEur(result.prediction.point)"></strong>
                    </p>

                    <div class="pt-4 border-t border-white/5 space-y-2">
                        <div class="flex items-center justify-between text-xs">
                            <span class="mono text-slate-500 uppercase tracking-widest">Confiance</span>
                            <span class="font-semibold text-pink-400" x-text="`${Math.round(result.prediction.confidence * 100)}%`"></span>
                        </div>
                        <div class="h-1.5 rounded-full bg-white/5 overflow-hidden">
                            <div class="h-full bg-gradient-to-r from-red-500 via-pink-500 to-indigo-500 transition-all duration-700"
                                 :style="`width: ${Math.round(result.prediction.confidence * 100)}%`"></div>
                        </div>
                        <p class="text-[10px] text-slate-500 pt-2 leading-relaxed">
                            Calculé sur <strong class="text-slate-300" x-text="result.model.training_size"></strong> offres du marché tech FR
                            · <strong class="text-slate-300" x-text="result.model.feature_count"></strong> features.
                        </p>
                    </div>
                </div>
            </template>

            <template x-if="result && !result.available">
                <div class="pt-4 text-amber-400">
                    <p class="text-sm" x-text="result.reason"></p>
                </div>
            </template>
        </div>

        <!-- Note méthode -->
        <div class="glass p-5 text-xs text-slate-400 leading-relaxed">
            <p class="mono text-[10px] text-slate-500 uppercase tracking-widest mb-2">Méthode</p>
            <p>
                RandomForest (100 arbres) prédit <code class="mono text-cyan-300">salary_min</code> à partir de
                la ville, du département, de l'expérience, du contrat et des technos.
                La fourchette P25–P75 vient de la dispersion inter-arbres ; la confiance décroît avec l'écart-type.
            </p>
        </div>
    </section>

</div>

<script>
function simulatorForm() {
    return {
        form: {
            city: '',
            department: '',
            contract: 'CDI',
            experience: '3 An(s)',
            technologies: [],
        },
        result: null,
        error: null,
        loading: false,

        toggleTech(name) {
            const i = this.form.technologies.indexOf(name);
            if (i >= 0) {
                this.form.technologies.splice(i, 1);
            } else if (this.form.technologies.length < 10) {
                this.form.technologies.push(name);
            }
        },

        fmtK(n) { return Math.round(n / 1000) + ' k€'; },
        fmtEur(n) { return new Intl.NumberFormat('fr-FR').format(n) + ' €'; },

        async simulate() {
            this.error = null;
            this.result = null;
            this.loading = true;
            try {
                const res = await fetch('http://localhost:5001/simulator/salary', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(this.form),
                });
                if (!res.ok) throw new Error(`API ${res.status}`);
                this.result = await res.json();
            } catch (e) {
                this.error = `Erreur : ${e.message}. Vérifie que l'API tourne sur :5001.`;
            } finally {
                this.loading = false;
            }
        },
    };
}
</script>

</div>

{% endblock %}
