{% extends 'layout.twig' %}
{% block title %}Se désabonner{% endblock %}

{% block content %}
<section class="max-w-xl mx-auto py-8">
    <h1 class="text-2xl font-bold mb-4">Désabonnement</h1>

    {% if result and result.type == 'error' %}
        <div class="bg-red-50 dark:bg-red-950/30 border border-red-200 dark:border-red-900 text-red-700 dark:text-red-300 rounded-lg p-4">
            ❌ {{ result.msg }}
        </div>
    {% elseif result and result.type == 'success' %}
        <div class="bg-emerald-50 dark:bg-emerald-950/30 border border-emerald-200 dark:border-emerald-900 text-emerald-700 dark:text-emerald-300 rounded-lg p-4">
            ✓ {{ result.msg }}
        </div>
        <a href="/" class="inline-block mt-4 text-brand-600 hover:underline">← Retour à l'accueil</a>
    {% elseif alert %}
        <p class="text-gray-700 dark:text-gray-300 mb-4">
            Tu vas désactiver l'alerte pour <strong>{{ alert.email }}</strong> avec les filtres suivants :
        </p>
        <ul class="list-disc list-inside text-sm text-gray-600 dark:text-gray-400 mb-6">
            {% if alert.filter_keyword %}<li>Mot-clé : <b>{{ alert.filter_keyword }}</b></li>{% endif %}
            {% if alert.filter_city %}<li>Ville : <b>{{ alert.filter_city }}</b></li>{% endif %}
            {% if alert.filter_tech %}<li>Techno : <b>{{ alert.filter_tech }}</b></li>{% endif %}
            {% if alert.filter_contract %}<li>Contrat : <b>{{ alert.filter_contract }}</b></li>{% endif %}
            {% if alert.filter_salary_min %}<li>Salaire ≥ <b>{{ alert.filter_salary_min }} €</b></li>{% endif %}
        </ul>
        <p class="text-xs text-gray-500 dark:text-gray-400 mb-6">
            Créée le {{ alert.created_at|slice(0, 10) }} · {{ alert.notification_count }} notification(s) envoyée(s)
        </p>
        <form method="get" action="/unsubscribe.php">
            <input type="hidden" name="token" value="{{ token }}">
            <input type="hidden" name="confirm" value="1">
            <button type="submit"
                    class="px-5 py-2.5 rounded-md bg-red-600 hover:bg-red-700 text-white font-medium">
                Confirmer le désabonnement
            </button>
            <a href="/" class="ml-3 px-5 py-2.5 rounded-md border border-gray-300 dark:border-gray-700 hover:bg-gray-100 dark:hover:bg-gray-800 inline-block">
                Annuler
            </a>
        </form>
    {% endif %}
</section>
{% endblock %}
