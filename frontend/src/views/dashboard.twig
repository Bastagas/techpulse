{% extends 'layout.twig' %}
{% block title %}Dashboard analytique{% endblock %}

{% block content %}
<section class="mb-8">
    <h1 class="text-3xl font-bold tracking-tight">Dashboard analytique</h1>
    <p class="mt-1 text-gray-600 dark:text-gray-400">
        Vue d'ensemble en temps réel du marché de l'emploi tech en France.
        {% if stats.last_scraped %}<span class="mx-2">·</span>Dernière MAJ : {{ stats.last_scraped|ago }}{% endif %}
    </p>
</section>

{# ─── KPI cards ─────────────────────── #}
<section class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-3 mb-8">
    {% set kpis = [
        {label: 'Offres actives', value: stats.total, accent: 'text-brand-600'},
        {label: 'Entreprises', value: stats.companies, accent: 'text-purple-600'},
        {label: 'Villes', value: stats.cities, accent: 'text-emerald-600'},
        {label: 'Avec salaire', value: stats.with_salary, accent: 'text-amber-600'},
        {label: 'Salaire médian', value: salary_stats.median, accent: 'text-emerald-600', suffix: ' €'},
        {label: 'Technos uniques', value: top_techs|length, accent: 'text-pink-600', suffix: '+'}
    ] %}
    {% for kpi in kpis %}
    <div class="bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-800 rounded-xl p-4">
        <p class="text-xs uppercase tracking-wide text-gray-500 dark:text-gray-400 font-semibold">{{ kpi.label }}</p>
        <p class="mt-1 text-2xl font-bold {{ kpi.accent }}">{{ (kpi.value ?? 0)|number_format(0, ',', ' ') }}{{ kpi.suffix|default('') }}</p>
    </div>
    {% endfor %}
</section>

{# ─── Row 1 : Top techs + Contrats ──── #}
<section class="grid grid-cols-1 lg:grid-cols-3 gap-4 mb-8">
    <div class="lg:col-span-2 bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-800 rounded-xl p-5">
        <h2 class="text-lg font-semibold mb-4">Top 20 technologies demandées</h2>
        <div class="h-80"><canvas id="chart-techs"></canvas></div>
    </div>
    <div class="bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-800 rounded-xl p-5">
        <h2 class="text-lg font-semibold mb-4">Types de contrats</h2>
        <div class="h-80"><canvas id="chart-contracts"></canvas></div>
    </div>
</section>

{# ─── Row 2 : Heatmap + Salaires ─────── #}
<section class="grid grid-cols-1 lg:grid-cols-3 gap-4 mb-8">
    <div class="lg:col-span-2 bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-800 rounded-xl p-5">
        <h2 class="text-lg font-semibold mb-4">Distribution géographique · {{ geo|length }} villes</h2>
        <div id="map" class="h-96 rounded-lg overflow-hidden border border-gray-200 dark:border-gray-800"></div>
    </div>
    <div class="bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-800 rounded-xl p-5">
        <h2 class="text-lg font-semibold mb-4">Distribution des salaires</h2>
        {% if salary_stats.count > 0 %}
        <dl class="grid grid-cols-2 gap-3 mb-4">
            <div>
                <dt class="text-xs uppercase text-gray-500 dark:text-gray-400">Médiane</dt>
                <dd class="text-xl font-bold text-emerald-600">{{ salary_stats.median|salary }}</dd>
            </div>
            <div>
                <dt class="text-xs uppercase text-gray-500 dark:text-gray-400">Moyenne</dt>
                <dd class="text-xl font-bold">{{ salary_stats.mean|number_format(0, ',', ' ') }} €</dd>
            </div>
            <div>
                <dt class="text-xs uppercase text-gray-500 dark:text-gray-400">25ᵉ percentile</dt>
                <dd class="text-lg font-semibold">{{ salary_stats.p25|salary }}</dd>
            </div>
            <div>
                <dt class="text-xs uppercase text-gray-500 dark:text-gray-400">75ᵉ percentile</dt>
                <dd class="text-lg font-semibold">{{ salary_stats.p75|salary }}</dd>
            </div>
        </dl>
        <div class="flex justify-between text-xs text-gray-500 dark:text-gray-400 pt-3 border-t border-gray-200 dark:border-gray-800">
            <span>min : {{ salary_stats.min|salary }}</span>
            <span>max : {{ salary_stats.max|salary }}</span>
        </div>
        <p class="mt-3 text-xs text-gray-500 dark:text-gray-400">
            Calculé sur <strong>{{ salary_stats.count }}</strong> offres ayant un salaire renseigné.
        </p>
        {% else %}
        <p class="text-gray-500 dark:text-gray-400">Pas encore d'offres avec salaire en BDD.</p>
        {% endif %}
    </div>
</section>

{# ─── Row 3 : Villes + Timeline ──────── #}
<section class="grid grid-cols-1 lg:grid-cols-2 gap-4">
    <div class="bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-800 rounded-xl p-5">
        <h2 class="text-lg font-semibold mb-4">Top 15 villes</h2>
        <div class="h-80"><canvas id="chart-cities"></canvas></div>
    </div>
    <div class="bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-800 rounded-xl p-5">
        <h2 class="text-lg font-semibold mb-4">Offres publiées · 30 derniers jours</h2>
        <div class="h-80"><canvas id="chart-timeline"></canvas></div>
    </div>
</section>

{# ─── Data bundled as JSON for JS ─────── #}
<script id="dashboard-data" type="application/json">
{{ {
    top_techs: top_techs,
    cities: cities,
    contracts: contracts,
    timeline: timeline,
    geo: geo
}|json_encode|raw }}
</script>

{# ─── Chart.js + Leaflet ─────────────── #}
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.4/dist/chart.umd.min.js"></script>
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css">
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

<script>
(() => {
    const data = JSON.parse(document.getElementById('dashboard-data').textContent);

    const CATEGORY_COLORS = {
        language:    '#3b82f6', framework:   '#a855f7', database:    '#10b981',
        cloud:       '#f97316', tool:        '#f59e0b', library:     '#ec4899',
        methodology: '#64748b',
    };

    const dark = document.documentElement.classList.contains('dark');
    const gridColor = dark ? 'rgba(255,255,255,0.08)' : 'rgba(0,0,0,0.06)';
    const textColor = dark ? '#cbd5e1' : '#475569';
    Chart.defaults.color = textColor;
    Chart.defaults.borderColor = gridColor;
    Chart.defaults.font.family = 'Inter, ui-sans-serif, system-ui, sans-serif';

    // ─── Top technos (horizontal bar) ───
    new Chart(document.getElementById('chart-techs'), {
        type: 'bar',
        data: {
            labels: data.top_techs.map(t => t.name),
            datasets: [{
                label: 'Offres',
                data: data.top_techs.map(t => t.count),
                backgroundColor: data.top_techs.map(t => CATEGORY_COLORS[t.category] || '#94a3b8'),
                borderRadius: 4,
            }],
        },
        options: {
            indexAxis: 'y',
            responsive: true,
            maintainAspectRatio: false,
            plugins: { legend: { display: false } },
            scales: {
                x: { grid: { color: gridColor }, beginAtZero: true },
                y: { grid: { display: false } },
            },
        },
    });

    // ─── Contracts (doughnut) ───
    const palette = ['#3b82f6', '#a855f7', '#10b981', '#f59e0b', '#ec4899', '#64748b', '#f97316', '#14b8a6'];
    new Chart(document.getElementById('chart-contracts'), {
        type: 'doughnut',
        data: {
            labels: data.contracts.map(c => c.contract_type),
            datasets: [{
                data: data.contracts.map(c => c.count),
                backgroundColor: palette,
                borderWidth: 0,
            }],
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            cutout: '60%',
            plugins: { legend: { position: 'bottom' } },
        },
    });

    // ─── Villes (vertical bar) ───
    new Chart(document.getElementById('chart-cities'), {
        type: 'bar',
        data: {
            labels: data.cities.map(c => c.city),
            datasets: [{
                label: 'Offres',
                data: data.cities.map(c => c.count),
                backgroundColor: '#3b82f6',
                borderRadius: 4,
            }],
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: { legend: { display: false } },
            scales: {
                x: { grid: { display: false }, ticks: { maxRotation: 45, minRotation: 45 } },
                y: { grid: { color: gridColor }, beginAtZero: true },
            },
        },
    });

    // ─── Timeline (line) ───
    new Chart(document.getElementById('chart-timeline'), {
        type: 'line',
        data: {
            labels: data.timeline.map(t => t.date),
            datasets: [{
                label: 'Offres/jour',
                data: data.timeline.map(t => t.count),
                borderColor: '#10b981',
                backgroundColor: 'rgba(16, 185, 129, 0.15)',
                fill: true,
                tension: 0.3,
                pointRadius: 3,
                pointHoverRadius: 5,
            }],
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: { legend: { display: false } },
            scales: {
                x: { grid: { display: false } },
                y: { grid: { color: gridColor }, beginAtZero: true },
            },
        },
    });

    // ─── Heatmap (Leaflet circles) ───
    if (data.geo.length > 0) {
        const map = L.map('map').setView([46.7, 2.5], 6);
        L.tileLayer(dark
            ? 'https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png'
            : 'https://{s}.basemaps.cartocdn.com/light_all/{z}/{x}/{y}{r}.png', {
            attribution: '&copy; OpenStreetMap &copy; CartoDB',
            maxZoom: 18,
        }).addTo(map);

        const maxCount = Math.max(...data.geo.map(p => p.count));
        data.geo.forEach(p => {
            const radius = 5 + (p.count / maxCount) * 25;
            L.circleMarker([p.lat, p.lng], {
                radius: radius,
                fillColor: '#3b82f6',
                color: '#1e40af',
                weight: 1,
                fillOpacity: 0.55,
            }).bindPopup(`<strong>${p.city}</strong><br>${p.count} offre${p.count > 1 ? 's' : ''}`)
              .addTo(map);
        });
    }
})();
</script>
{% endblock %}
