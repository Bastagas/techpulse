{% extends 'layout.twig' %}
{% set active_page = 'dashboard' %}
{% set ticker_total = stats.total %}
{% set ticker_companies = stats.companies %}

{% block title %}Dashboard{% endblock %}

{% block head_extra %}
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css">
{% endblock %}

{% block content %}
<section class="reveal flex items-end justify-between mb-8 flex-wrap gap-3" style="animation-delay: 100ms">
    <div>
        <p class="mono text-xs text-slate-400 tracking-widest uppercase mb-2">Dashboard analytique</p>
        <h1 class="text-4xl md:text-5xl font-bold tracking-[-0.03em] leading-tight">
            Vue d'ensemble <span class="gradient-accent italic">en temps réel</span>
        </h1>
        {% if stats.last_scraped %}
        <p class="text-slate-400 mt-2 mono text-sm">Dernière MAJ {{ stats.last_scraped|ago }}</p>
        {% endif %}
    </div>
    <div class="flex items-center gap-2">
        <a href="/export.php?format=csv" class="glass px-4 py-2 text-sm text-white hover:bg-white/10" style="border-radius: 9999px;">Exporter CSV</a>
        <a href="http://localhost:5001/docs" target="_blank" rel="noopener" class="cta-red px-4 py-2 rounded-full text-sm font-medium">API Swagger</a>
    </div>
</section>

{# ─── KPI ribbon ─── #}
<section class="reveal grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-3 mb-6" style="animation-delay: 180ms">
    {% set kpis = [
        {label: 'Offres actives', value: stats.total, suffix: ''},
        {label: 'Entreprises', value: stats.companies, suffix: ''},
        {label: 'Villes', value: stats.cities, suffix: ''},
        {label: 'Avec salaire', value: stats.with_salary, suffix: ''},
        {label: 'Sal. médian', value: salary_stats.median, suffix: ' €', accent: true},
        {label: 'Technos', value: top_techs|length, suffix: '', accent: true}
    ] %}
    {% for kpi in kpis %}
    <div class="glass-strong p-4 relative overflow-hidden">
        {% if kpi.accent %}<div class="orb w-16 h-16 bg-pink-500/20 -top-2 -right-2"></div>{% endif %}
        <p class="mono text-[10px] text-slate-500 uppercase tracking-widest">{{ kpi.label }}</p>
        <p class="text-2xl md:text-3xl font-bold mt-1 {% if kpi.accent %}gradient-accent{% endif %}">{{ (kpi.value ?? 0)|number_format(0, ',', ' ') }}{{ kpi.suffix }}</p>
    </div>
    {% endfor %}
</section>

{# ─── Row 1 : Top techs + Contrats ─── #}
<section class="reveal grid grid-cols-1 lg:grid-cols-3 gap-4 mb-6" style="animation-delay: 260ms">
    <div class="lg:col-span-2 glass-strong p-6">
        <div class="flex items-end justify-between mb-4">
            <div>
                <p class="mono text-xs text-slate-400 uppercase tracking-widest mb-1">Classement</p>
                <h2 class="text-xl font-bold">Top 20 technologies demandées</h2>
            </div>
        </div>
        <div class="h-80"><canvas id="chart-techs"></canvas></div>
    </div>
    <div class="glass-strong p-6 relative overflow-hidden">
        <div class="orb w-32 h-32 bg-red-500/20 -top-4 -right-4"></div>
        <p class="mono text-xs text-slate-400 uppercase tracking-widest mb-1">Répartition</p>
        <h2 class="text-xl font-bold mb-4">Types de contrats</h2>
        <div class="h-80"><canvas id="chart-contracts"></canvas></div>
    </div>
</section>

{# ─── Row 2 : Heatmap + Salaires ─── #}
<section class="reveal grid grid-cols-1 lg:grid-cols-3 gap-4 mb-6" style="animation-delay: 340ms">
    <div class="lg:col-span-2 glass-strong p-6">
        <div class="flex items-end justify-between mb-4">
            <div>
                <p class="mono text-xs text-slate-400 uppercase tracking-widest mb-1">Géographie</p>
                <h2 class="text-xl font-bold">{{ geo|length }} villes géolocalisées</h2>
            </div>
            <span class="mono text-[11px] text-slate-500">API Adresse · Data Gouv</span>
        </div>
        <div id="map" class="h-96 rounded-2xl" style="border:1px solid rgba(255,255,255,0.06);"></div>
    </div>
    <div class="glass-strong p-6 relative overflow-hidden iridescent">
        <div class="orb w-40 h-40 bg-red-500/25 -top-6 -right-8"></div>
        <p class="mono text-xs text-slate-400 uppercase tracking-widest mb-2">Salaires</p>
        <h2 class="text-xl font-bold mb-4">Distribution</h2>
        {% if salary_stats.count > 0 %}
        <p class="text-4xl font-bold mb-6 gradient-text">{{ salary_stats.median|salary }}<span class="text-sm text-slate-400 font-normal ml-2">médian</span></p>
        <dl class="grid grid-cols-2 gap-3 mb-4 pt-4 border-t border-white/5">
            <div>
                <dt class="mono text-[10px] text-slate-500 uppercase">Moyenne</dt>
                <dd class="text-lg font-semibold">{{ salary_stats.mean|number_format(0, ',', ' ') }} €</dd>
            </div>
            <div>
                <dt class="mono text-[10px] text-slate-500 uppercase">P25</dt>
                <dd class="text-lg font-semibold">{{ salary_stats.p25|salary }}</dd>
            </div>
            <div>
                <dt class="mono text-[10px] text-slate-500 uppercase">P75</dt>
                <dd class="text-lg font-semibold">{{ salary_stats.p75|salary }}</dd>
            </div>
            <div>
                <dt class="mono text-[10px] text-slate-500 uppercase">Observations</dt>
                <dd class="text-lg font-semibold">{{ salary_stats.count }}</dd>
            </div>
        </dl>
        <div class="flex justify-between text-xs text-slate-500 mono pt-3 border-t border-white/5">
            <span>min {{ salary_stats.min|salary }}</span>
            <span>max {{ salary_stats.max|salary }}</span>
        </div>
        {% else %}
        <p class="text-slate-500">Pas encore d'offres avec salaire.</p>
        {% endif %}
    </div>
</section>

{# ─── Row 3 : Villes + Timeline ─── #}
<section class="reveal grid grid-cols-1 lg:grid-cols-2 gap-4 mb-6" style="animation-delay: 420ms">
    <div class="glass-strong p-6">
        <p class="mono text-xs text-slate-400 uppercase tracking-widest mb-1">Top 15</p>
        <h2 class="text-xl font-bold mb-4">Villes qui recrutent</h2>
        <div class="h-80"><canvas id="chart-cities"></canvas></div>
    </div>
    <div class="glass-strong p-6">
        <p class="mono text-xs text-slate-400 uppercase tracking-widest mb-1">30 derniers jours</p>
        <h2 class="text-xl font-bold mb-4">Offres publiées</h2>
        <div class="h-80"><canvas id="chart-timeline"></canvas></div>
    </div>
</section>

{# ─── Corrélation matrix ─── #}
{% if correlations.techs|length >= 3 %}
<section class="reveal glass-strong p-6 mb-6 relative overflow-hidden" style="animation-delay: 500ms">
    <div class="orb w-64 h-64 bg-indigo-500/15 -top-20 -right-20"></div>
    <div class="flex items-end justify-between mb-4">
        <div>
            <p class="mono text-xs text-slate-400 uppercase tracking-widest mb-1">Corrélation technologies</p>
            <h2 class="text-xl font-bold">Qui va avec qui</h2>
            <p class="text-sm text-slate-400 mt-1">
                <code class="mono text-xs">P(ligne | colonne)</code> — offres contenant la colonne qui contiennent aussi la ligne
            </p>
        </div>
    </div>
    <div class="overflow-x-auto">
        <table class="min-w-full text-xs tabular-nums">
            <thead>
                <tr>
                    <th class="p-2"></th>
                    {% for tech in correlations.techs %}
                    <th class="p-2 text-center font-semibold whitespace-nowrap text-slate-400" style="writing-mode: vertical-rl; transform: rotate(180deg); height: 100px;">
                        {{ tech.name }}
                    </th>
                    {% endfor %}
                </tr>
            </thead>
            <tbody>
                {% for row_tech in correlations.techs %}
                <tr>
                    <td class="p-2 text-sm font-semibold text-left whitespace-nowrap">{{ row_tech.name }}</td>
                    {% for col_tech in correlations.techs %}
                        {% if row_tech.name == col_tech.name %}
                            <td class="p-2 text-center text-slate-600">—</td>
                        {% else %}
                            {% set match = correlations.pairs|filter(p => p.a == col_tech.name and p.b == row_tech.name)|first %}
                            {% set conf = match ? match.conf : 0 %}
                            {% set pct = (conf * 100)|round %}
                            {% set opacity = (conf > 0 ? (0.15 + conf * 0.7)|round(2) : 0) %}
                            <td class="p-2 text-center transition-transform hover:scale-110 hover:z-10 relative" style="background-color: rgba(220, 38, 38, {{ opacity }}); color: {{ conf > 0.5 ? 'white' : '#cbd5e1' }};"
                                title="{{ match ? match.count ~ ' offres communes · ' ~ pct ~ '%' : 'Aucune offre commune' }}">
                                {{ pct > 0 ? pct ~ '%' : '·' }}
                            </td>
                        {% endif %}
                    {% endfor %}
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
    <div class="mt-4 flex items-center gap-3 text-xs text-slate-500">
        <span>Intensité</span>
        <div class="h-2 w-40 rounded-full bg-gradient-to-r from-red-500/15 via-red-500/40 to-red-500/70"></div>
        <span>+</span>
        <span class="ml-auto mono">Hover les cellules pour le détail</span>
    </div>
</section>
{% endif %}

{# ─── Data bundle ─── #}
<script id="dashboard-data" type="application/json">
{{ {
    top_techs: top_techs,
    cities: cities,
    contracts: contracts,
    timeline: timeline,
    geo: geo
}|json_encode|raw }}
</script>
{% endblock %}

{% block scripts_extra %}
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.4/dist/chart.umd.min.js"></script>
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script>
(() => {
    const data = JSON.parse(document.getElementById('dashboard-data').textContent);

    const CATEGORY_COLORS = {
        language:    '#EF4444', framework:   '#A855F7', database:    '#22D3EE',
        cloud:       '#EC4899', tool:        '#F59E0B', library:     '#6366F1',
        methodology: '#64748B',
    };

    const gridColor = 'rgba(255,255,255,0.06)';
    const textColor = '#94A3B8';
    Chart.defaults.color = textColor;
    Chart.defaults.borderColor = gridColor;
    Chart.defaults.font.family = 'Space Grotesk, ui-sans-serif, system-ui, sans-serif';

    // Top techs (horizontal bar)
    new Chart(document.getElementById('chart-techs'), {
        type: 'bar',
        data: {
            labels: data.top_techs.map(t => t.name),
            datasets: [{
                label: 'Offres',
                data: data.top_techs.map(t => t.count),
                backgroundColor: data.top_techs.map(t => CATEGORY_COLORS[t.category] || '#94a3b8'),
                borderRadius: 4,
            }],
        },
        options: {
            indexAxis: 'y',
            responsive: true,
            maintainAspectRatio: false,
            plugins: { legend: { display: false } },
            scales: {
                x: { grid: { color: gridColor }, beginAtZero: true },
                y: { grid: { display: false } },
            },
        },
    });

    // Contracts (doughnut)
    const palette = ['#EF4444', '#EC4899', '#6366F1', '#22D3EE', '#F59E0B', '#A855F7', '#10B981', '#F97316'];
    new Chart(document.getElementById('chart-contracts'), {
        type: 'doughnut',
        data: {
            labels: data.contracts.map(c => c.contract_type),
            datasets: [{
                data: data.contracts.map(c => c.count),
                backgroundColor: palette,
                borderWidth: 0,
            }],
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            cutout: '65%',
            plugins: { legend: { position: 'bottom', labels: { boxWidth: 10, padding: 10 } } },
        },
    });

    // Cities (vertical bar)
    new Chart(document.getElementById('chart-cities'), {
        type: 'bar',
        data: {
            labels: data.cities.map(c => c.city),
            datasets: [{
                label: 'Offres',
                data: data.cities.map(c => c.count),
                backgroundColor: 'rgba(220, 38, 38, 0.8)',
                borderRadius: 4,
            }],
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: { legend: { display: false } },
            scales: {
                x: { grid: { display: false }, ticks: { maxRotation: 45, minRotation: 45 } },
                y: { grid: { color: gridColor }, beginAtZero: true },
            },
        },
    });

    // Timeline (line area)
    new Chart(document.getElementById('chart-timeline'), {
        type: 'line',
        data: {
            labels: data.timeline.map(t => t.date),
            datasets: [{
                label: 'Offres/jour',
                data: data.timeline.map(t => t.count),
                borderColor: '#EF4444',
                backgroundColor: 'rgba(239, 68, 68, 0.15)',
                fill: true,
                tension: 0.3,
                pointRadius: 3,
                pointHoverRadius: 6,
                pointBackgroundColor: '#EF4444',
                pointBorderColor: '#050810',
                pointBorderWidth: 2,
            }],
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: { legend: { display: false } },
            scales: {
                x: { grid: { display: false } },
                y: { grid: { color: gridColor }, beginAtZero: true },
            },
        },
    });

    // Heatmap Leaflet
    if (data.geo.length > 0) {
        const map = L.map('map', { attributionControl: false }).setView([46.7, 2.5], 6);
        L.tileLayer('https://{s}.basemaps.cartocdn.com/light_all/{z}/{x}/{y}{r}.png', { maxZoom: 18 }).addTo(map);
        const maxCount = Math.max(...data.geo.map(p => p.count));
        data.geo.forEach(p => {
            const radius = 6 + (p.count / maxCount) * 22;
            L.circleMarker([p.lat, p.lng], {
                radius: radius,
                fillColor: '#EF4444',
                color: '#B91C1C',
                weight: 1.5,
                fillOpacity: 0.6,
            }).bindPopup(`<strong>${p.city}</strong><br>${p.count} offre${p.count > 1 ? 's' : ''}`)
              .addTo(map);
        });
    }
})();
</script>
{% endblock %}
