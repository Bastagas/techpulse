{# Tech badge V4 — glassy, catégorisé par couleur brand #}
{% set colors = {
    'language':    'bg-red-500/15 border border-red-500/25 text-red-300',
    'framework':   'bg-purple-500/15 border border-purple-500/25 text-purple-300',
    'database':    'bg-cyan-500/15 border border-cyan-500/25 text-cyan-300',
    'cloud':       'bg-pink-500/15 border border-pink-500/25 text-pink-300',
    'tool':        'bg-amber-500/15 border border-amber-500/25 text-amber-300',
    'library':     'bg-indigo-500/15 border border-indigo-500/25 text-indigo-300',
    'methodology': 'bg-white/5 border border-white/10 text-slate-300',
} %}
<span class="inline-flex items-center text-[11px] font-medium px-2 py-0.5 rounded-full {{ colors[tech.category]|default(colors['methodology']) }}">
    {{ tech.display_name }}
</span>
