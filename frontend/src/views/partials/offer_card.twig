{# Offer card V4 — Liquid Glass #}
<div class="relative group">
    <label class="absolute top-3 left-3 z-10 opacity-60 hover:opacity-100 cursor-pointer" title="Ajouter au comparateur">
        <input type="checkbox" class="compare-checkbox w-4 h-4 rounded border-white/20 bg-white/5 text-red-500 focus:ring-red-500 focus:ring-offset-0" data-offer-id="{{ offer.id }}">
    </label>
    <a href="/offer.php?id={{ offer.id }}"
       class="block glass-strong p-5 pl-10 hover:bg-white/[0.06] transition-all relative overflow-hidden">
        <div class="orb w-32 h-32 bg-red-500/10 -top-4 -right-4 opacity-0 group-hover:opacity-100 transition-opacity"></div>

        <div class="flex items-start justify-between gap-3 mb-2">
            <h3 class="font-semibold text-white group-hover:text-red-400 transition-colors line-clamp-2 leading-snug text-base">
                {{ offer.title }}
            </h3>
            <div class="flex gap-1.5 shrink-0">
                {% if offer.contract_type %}
                <span class="text-[10px] font-medium px-2 py-0.5 rounded-full bg-white/5 border border-white/10 text-slate-300 mono uppercase tracking-wider">
                    {{ offer.contract_type }}
                </span>
                {% endif %}
            </div>
        </div>

        <p class="text-sm text-slate-400 mb-3">
            <span class="font-medium text-slate-300">{{ offer.company_name }}</span>
            {% if offer.city %}
            <span class="mx-1 text-slate-600">·</span>
            <span>{{ offer.city }}{% if offer.department_code %} ({{ offer.department_code }}){% endif %}</span>
            {% endif %}
        </p>

        {% if offer.description %}
        <p class="text-sm text-slate-400 line-clamp-2 mb-3">
            {{ offer.description|excerpt(180) }}
        </p>
        {% endif %}

        {% if offer.technologies|length > 0 %}
        <div class="flex flex-wrap items-center gap-1.5 mb-3">
            {% for tech in offer.technologies|slice(0, 6) %}
                {% include 'partials/tech_badge.twig' with { tech: tech } %}
            {% endfor %}
            {% if offer.technologies|length > 6 %}
            <span class="text-[11px] text-slate-500">+{{ offer.technologies|length - 6 }}</span>
            {% endif %}
        </div>
        {% endif %}

        <div class="flex items-center justify-between text-xs text-slate-500 pt-3 border-t border-white/5">
            <div class="flex items-center gap-3">
                {% if offer.salary_min %}
                <span class="font-semibold text-emerald-400">
                    {{ offer.salary_min|salary }}{% if offer.salary_max and offer.salary_max > offer.salary_min %} – {{ offer.salary_max|salary }}{% endif %}
                </span>
                {% endif %}
                {% if offer.seniority %}
                <span class="mono text-[10px] uppercase tracking-wider">
                    {% if offer.seniority == 'junior' %}Junior
                    {% elseif offer.seniority == 'mid' %}Confirmé
                    {% elseif offer.seniority == 'senior' %}Senior
                    {% elseif offer.seniority == 'lead' %}Lead{% endif %}
                </span>
                {% endif %}
                {% if offer.remote_policy == 'full_remote' %}
                <span class="text-cyan-400 mono text-[10px] uppercase tracking-wider">Full remote</span>
                {% elseif offer.remote_policy == 'hybrid' %}
                <span class="text-amber-400 mono text-[10px] uppercase tracking-wider">Hybride</span>
                {% endif %}
            </div>
            {% if offer.posted_at %}
            <span class="mono">{{ offer.posted_at|ago }}</span>
            {% endif %}
        </div>
    </a>
</div>
