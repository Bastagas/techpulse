<a href="/offer.php?id={{ offer.id }}"
   class="block group bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 hover:border-brand-500 dark:hover:border-brand-500 hover:shadow-lg transition-all p-5">
    <div class="flex items-start justify-between gap-4 mb-2">
        <h3 class="font-semibold text-gray-900 dark:text-white group-hover:text-brand-600 dark:group-hover:text-brand-400 line-clamp-2 leading-snug">
            {{ offer.title }}
        </h3>
        {% if offer.contract_type %}
        <span class="shrink-0 text-xs font-medium px-2 py-1 rounded bg-gray-100 dark:bg-gray-800 text-gray-700 dark:text-gray-300">
            {{ offer.contract_type }}
        </span>
        {% endif %}
    </div>

    <p class="text-sm text-gray-600 dark:text-gray-400 mb-3">
        <span class="font-medium text-gray-900 dark:text-gray-200">{{ offer.company_name }}</span>
        {% if offer.city %}
        <span class="mx-1">·</span>
        <span>{{ offer.city }}{% if offer.department_code %} ({{ offer.department_code }}){% endif %}</span>
        {% endif %}
    </p>

    {% if offer.description %}
    <p class="text-sm text-gray-600 dark:text-gray-400 line-clamp-2 mb-3">
        {{ offer.description|excerpt(180) }}
    </p>
    {% endif %}

    <div class="flex flex-wrap items-center gap-2 mb-3">
        {% for tech in offer.technologies|slice(0, 6) %}
            {% include 'partials/tech_badge.twig' with { tech: tech } %}
        {% endfor %}
        {% if offer.technologies|length > 6 %}
        <span class="text-xs text-gray-500 dark:text-gray-400">+{{ offer.technologies|length - 6 }}</span>
        {% endif %}
    </div>

    <div class="flex items-center justify-between text-xs text-gray-500 dark:text-gray-400">
        <div class="flex items-center gap-3">
            {% if offer.salary_min %}
            <span class="font-medium text-emerald-600 dark:text-emerald-400">
                {{ offer.salary_min|salary }}{% if offer.salary_max and offer.salary_max > offer.salary_min %} – {{ offer.salary_max|salary }}{% endif %}
            </span>
            {% endif %}
            {% if offer.experience_level %}
            <span>{{ offer.experience_level }}</span>
            {% endif %}
        </div>
        {% if offer.posted_at %}
        <span>{{ offer.posted_at|ago }}</span>
        {% endif %}
    </div>
</a>
